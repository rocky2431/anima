{
  "name": "@anase/anase-plugin-vscode",
  "type": "module",
  "version": "0.8.4",
  "private": true,
  "description": "Anase host plugin that bridges VS Code context and UI",
  "repository": {
    "type": "git",
    "url": "https://github.com/rocky2431/anima.git",
    "directory": "integrations/vscode/anase-plugin-vscode"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "pnpm run build",
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@anase/plugin-sdk": "workspace:*"
  }
}
