{
  "name": "@anase/server-sdk",
  "type": "module",
  "version": "0.8.4",
  "description": "Client-side SDK implementation for connecting to Anase server components and runtimes",
  "author": {
    "name": "Project Anase Team",
    "email": "team@anase.app",
    "url": "https://github.com/moeru-ai"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rocky2431/anima.git",
    "directory": "packages/server-sdk"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./utils/node": {
      "types": "./dist/utils/node/index.d.mts",
      "default": "./dist/utils/node/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "pnpm run build",
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anase/server-shared": "workspace:^",
    "crossws": "^0.4.3",
    "superjson": "catalog:"
  },
  "devDependencies": {
    "@moeru/std": "catalog:"
  }
}
